# ---- Postgres ----
POSTGRES_USER=arena
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=arena

# ---- Backend ----
DATABASE_URL=postgresql+psycopg://arena:change-me-in-prod@postgres:5432/arena
REDIS_URL=redis://redis:6379/0

# Submission sandbox runtime: runsc (gVisor, Linux prod) | runc (local/mac, NOT hardened)
ARENA_DOCKER_RUNTIME=runc

# DooD shared workdir — MUST be the same path on host and in the worker container.
# Linux prod: /srv/arena/work   |   macOS: a Docker-Desktop-shared path under $HOME
ARENA_WORK_DIR=/srv/arena/work

# Host docker group GID (Linux: `getent group docker | cut -d: -f3`). On Docker
# Desktop/macOS the socket is user-accessible; 0 is a safe default there.
DOCKER_GID=0

# ---- Frontend ----
API_ORIGIN=http://api:8000

# ---- Caddy (auto-HTTPS). Use a real domain + email in prod; localhost for local. ----
ARENA_DOMAIN=localhost
ARENA_ACME_EMAIL=admin@example.com
